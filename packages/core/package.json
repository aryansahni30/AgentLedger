{
  "name": "@agentledger/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core domain logic for AgentLedger — hash-chained ledger, task graph, verification, replay, governance.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aryansahni/AgentLeader",
    "directory": "packages/core"
  },
  "keywords": ["agentledger", "ledger", "verification", "ai-agent", "hash-chain"],
  "engines": { "node": ">=18" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "minimatch": "^10.2.5",
    "openai": "^6.45.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
