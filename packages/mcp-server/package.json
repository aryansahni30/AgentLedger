{
  "name": "agentledger-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server exposing AgentLedger ledger operations over stdio transport.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aryansahni/AgentLeader",
    "directory": "packages/mcp-server"
  },
  "keywords": ["agentledger", "mcp", "ai-agent", "ledger", "governance", "model-context-protocol"],
  "engines": { "node": ">=18" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentledger-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@agentledger/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
