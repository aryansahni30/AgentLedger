node_modules/
dist/
# Exception: ship ONLY the plugin's self-contained hook bundles, so git-subdir
# marketplace installs can run them directly. Everything else under any dist/
# (core, cli, server, visualizer) stays ignored.
!/packages/plugin/dist/
/packages/plugin/dist/*
!/packages/plugin/dist/*.cjs
.DS_Store
**/.DS_Store
*.js.map
*.d.ts.map
.agentledger/
.env

# compiled TS output emitted alongside source (some packages build in place)
**/src/**/*.js
**/src/**/*.d.ts
**/src/**/*.js.map
**/src/**/*.d.ts.map
# compiled config output (vitest/vite configs are authored in .ts)
**/vitest.config.js
**/vitest.config.d.ts
**/vite.config.js
**/vite.config.d.ts
vitest.workspace.js
vitest.workspace.d.ts
# incremental build info (regenerated, never source)
*.tsbuildinfo

# internal working notes
.brain/
